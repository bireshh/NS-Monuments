<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PrvaApp.Info"
             Title="Informations">
    <Grid>
        <Image Source="background.jpg" Opacity="0.3" Aspect="AspectFill"/>
        <ScrollView>
            <VerticalStackLayout>
                <Label></Label>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="8*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>
                
                <Border Grid.Column="1" StrokeShape="RoundRectangle 10">
                    <Image 
            x:Name="slika"
            />
                    <Border.Shadow>
                        <Shadow
        Brush="#80000000"
        Offset="0,8"
        Radius="15" />
                    </Border.Shadow>
                </Border>
                </Grid>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="8*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="1"
            x:Name="tekst" FontSize="Large"
            >
                        <Label.Shadow>
                            <Shadow
            Brush="#80000000"
            Offset="1,2"
            Radius="3" />
                        </Label.Shadow>
                    </Label>
                </Grid>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>