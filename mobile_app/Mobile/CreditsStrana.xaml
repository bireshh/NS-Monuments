<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:services="clr-namespace:PrvaApp"
             x:Class="PrvaApp.CreditsStrana"
             Title="Credits"
             >
    <Grid>
        <Image Source="background.jpg" Opacity="0.3" Aspect="AspectFill"/>
        <VerticalStackLayout Spacing="20">
            <Label></Label>
            <Label 
            x:Name="credits"
            Text=""
            FontSize="20"
            VerticalOptions="Center" 
            HorizontalOptions="Center"
            HorizontalTextAlignment="Center">
                <Label.Shadow>
                    <Shadow
            Brush="#80000000"
            Offset="1,2"
            Radius="3" />
                </Label.Shadow>
            </Label>
        </VerticalStackLayout>
    </Grid>
</ContentPage>